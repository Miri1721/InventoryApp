<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.CreateItemPage"
             Title="Create Item"
             BackgroundColor="#F7F9FC">

    <ScrollView>
        <VerticalStackLayout Padding="20,5,20,5" Spacing="10">
            <Label Text="Add a new item to your inventory"
                       FontSize="15"
                       TextColor="#6B7280" />

                <Frame Padding="20,10,20,0"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False"
                   HorizontalOptions="Fill">

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Item Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="NameEntry"
                               Placeholder="Enter item name"
                               ClearButtonVisibility="WhileEditing"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Description"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Enter description"
                                AutoSize="TextChanges"
                                HeightRequest="100"
                                BackgroundColor="#F9FAFB"
                                TextColor="#111827" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Category"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Label x:Name="CategoryNameLabel"
                               FontSize="15"
                               TextColor="#111827"
                               BackgroundColor="#F9FAFB"
                               Padding="12,14"
                               LineBreakMode="WordWrap" />      
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Unit"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="UnitEntry"
                               Placeholder="Pack / Carton / Tray / Bottle..."
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Supplier"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="SupplierEntry"
                               Placeholder="Enter supplier name"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Current Quantity"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="CurrentQuantityEntry"
                               Placeholder="0"
                               Keyboard="Numeric"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Minimum Threshold"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="MinimumThresholdEntry"
                               Placeholder="0"
                               Keyboard="Numeric"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <Button Text="Save Item"
                            Clicked="OnSaveClicked"
                            CornerRadius="10"
                            HeightRequest="48"
                            BackgroundColor="#1D4ED8"
                            TextColor="White"
                            FontAttributes="Bold" MaximumWidthRequest="150"/>

                    <Label x:Name="MessageLabel"
                           TextColor="#B91C1C"
                           FontSize="14"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>