<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.EditItemPage"
             Title="Edit Item">

    <ScrollView>
        <VerticalStackLayout Padding="20,0,20,0"
                             Spacing="14">

            <Frame Padding="16"
                   CornerRadius="16"
                   BorderColor="#D9D9D9"
                   HasShadow="False">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Item Name"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Enter item name"
                           ClearButtonVisibility="WhileEditing" />

                    <Label Text="Description"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Enter description"
                            AutoSize="TextChanges"
                            HeightRequest="100" />

                    <Label Text="Unit"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Entry x:Name="UnitEntry"
                           Placeholder="Enter unit" />

                    <Label Text="Supplier"
                           FontSize="16"
                           FontAttributes="Bold" /> 
                    <Entry x:Name="SupplierEntry"
                           Placeholder="Enter supplier" />

                    <Label Text="Minimum Threshold"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Entry x:Name="MinimumThresholdEntry"
                           Placeholder="0"
                           Keyboard="Numeric" />   
                </VerticalStackLayout>
            </Frame>

            <Button Text="Save Changes"
                    Clicked="OnSaveClicked"
                    CornerRadius="5" HorizontalOptions="Center"
                    HeightRequest="40"
                    MaximumHeightRequest="140"
                    BackgroundColor="DarkBlue"/>     

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>