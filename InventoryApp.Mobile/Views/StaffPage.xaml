<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.StaffPage"
             Title="Staff">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,0,20,0">
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Button Text="Deleted Staff Users"
                    Clicked="OnDeletedStaffUsersClicked"
                    CornerRadius="8"
                    HeightRequest="42"
                    MaximumWidthRequest="220"
                    HorizontalOptions="Start"
                    BackgroundColor="White"
                    BorderColor="DarkBlue"
                    BorderWidth="2"
                    TextColor="Black" />

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="2"
                        x:Name="UsersCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding FullName}"
                                   FontSize="20"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Email, StringFormat='Email: {0}'}"
                                   FontSize="15" />

                            <Label Text="{Binding Role, StringFormat='Role: {0}'}"
                                   FontSize="15"
                                   TextColor="DarkBlue" />

                            <Button Text="Delete"
                                    Clicked="OnDeleteClicked"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding CanDelete}"
                                    CornerRadius="5"
                                    HeightRequest="40"
                                    MaximumWidthRequest="140"
                                    HorizontalOptions="Start"
                                    BackgroundColor="#B00020"
                                    TextColor="White" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>