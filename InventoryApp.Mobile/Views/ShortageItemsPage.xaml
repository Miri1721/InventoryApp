<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ShortageItemsPage"
             Title="Shortage Items">

    <Grid RowDefinitions="Auto, *"
          Padding="20">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="12">

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="ShortageItemsCollectionView"
                        Margin="0,16,0,0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12"
                           Padding="16"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#555555"
                                   LineBreakMode="WordWrap" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Unit, StringFormat='Unit: {0}'}"
                                       FontSize="14" />

                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding CurrentQuantity, StringFormat='Current: {0}'}"
                                       FontSize="14" />

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding MinimumThreshold, StringFormat='Minimum Threshold: {0}'}"
                                       FontSize="14" />
                            </Grid>

                            <Label Text="{Binding MissingText}"
                                   TextColor="DarkRed"
                                   FontAttributes="Bold"
                                   FontSize="15" />

                            <Label Text="Below Threshold"
                                   TextColor="Red"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <HorizontalStackLayout Spacing="10">
                                <Button Grid.Column="0"
                                        Text="Edit / Restock"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                       CornerRadius="5" HorizontalOptions="Center"
  HeightRequest="40"
  MaximumHeightRequest="140"
  BackgroundColor="DarkBlue"/>

                                <Button Grid.Column="1"
                                        Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                       CornerRadius="5" HorizontalOptions="Center"
  HeightRequest="40"
  MaximumHeightRequest="140"
  BackgroundColor="DarkBlue"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>