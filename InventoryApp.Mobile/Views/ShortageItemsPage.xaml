<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ShortageItemsPage"
             Title="Items To Reorder">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,0,20,0">

        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <Grid x:Name="SearchSection"
              Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="20"
              Margin="0,0,0,10"
              IsVisible="False">
            <VerticalStackLayout Grid.Column="0"
                         Spacing="6" Padding="0,0,0,5"
                         HorizontalOptions="Fill"
                         VerticalOptions="Start">
                <Label Text="Search by Category"
                       FontSize="14"
                       FontAttributes="Bold" />
                <SearchBar x:Name="CategorySearchBar"
                           Placeholder="Type category name"
                           TextChanged="OnSearchTextChanged"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />  
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                         Spacing="6" Padding="0,0,0,5"
                         HorizontalOptions="Fill"
                         VerticalOptions="Start">
                <Label Text="Search by Item"
                       FontSize="14"
                       FontAttributes="Bold" />
                <SearchBar x:Name="ItemSearchBar"
                           Placeholder="Type item name"
                           TextChanged="OnSearchTextChanged"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <CollectionView Grid.Row="2"
                        x:Name="ShortageItemsCollectionView"
                        Margin="0,8,0,0"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0"
                           Padding="16"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding CategoryName, StringFormat='Category: {0}'}"
                                   FontSize="14"
                                   TextColor="DarkBlue"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#555555"
                                   LineBreakMode="WordWrap" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Unit, StringFormat='Unit: {0}'}"
                                       FontSize="14" />

                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding CurrentQuantity, StringFormat='Current: {0}'}"
                                       FontSize="14" />

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding MinimumThreshold, StringFormat='Minimum Threshold: {0}'}"
                                       FontSize="14" />
                            </Grid>

                            <Label Text="{Binding MissingText}"
                                   TextColor="DarkRed"
                                   FontAttributes="Bold"
                                   FontSize="15" />

                            <Label Text="Below Threshold"
                                   TextColor="Red"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Stretch"
                                        AlignContent="Start">

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="110"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="120"
                                        FlexLayout.Grow="1" />          

                                <Button Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="130"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Record Movement"
                                        Clicked="OnRecordMovementClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="160"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="180"
                                        FlexLayout.Grow="1" />

                                <Button Text="View History"
                                        Clicked="OnViewHistoryClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="140"
                                        BackgroundColor="White"
                                        BorderColor="DarkBlue"
                                        BorderWidth="2"
                                        TextColor="Black"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />  
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>