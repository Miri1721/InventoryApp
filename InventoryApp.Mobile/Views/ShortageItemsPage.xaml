<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ShortageItemsPage"
             Title="Items To Reorder"
             BackgroundColor="#F7F9FC">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,5,20,0" RowSpacing="5">

        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <Label Text="Track items that are below their minimum threshold"
                       FontSize="15"
                       TextColor="#6B7280" />

            <Label x:Name="MessageLabel"
                   TextColor="#B91C1C"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
            <Button x:Name="ExportReorderReportButton"
                     Text="Export Reorder Report"
                     Clicked="OnExportReorderReportClicked"
                     CornerRadius="10"
                     HeightRequest="48"
                     MaximumWidthRequest="220"
                     HorizontalOptions="Start"
                     BackgroundColor="White"
                     BorderColor="#D1D5DB"
                     BorderWidth="1.5"
                     TextColor="#111827"
                     FontAttributes="Bold" />   
        </VerticalStackLayout>

        <Frame Grid.Row="1"
               x:Name="SearchSection"
               IsVisible="False"
               Padding="16"
               CornerRadius="18"
               BorderColor="#E5E7EB"
               BackgroundColor="White"
               HasShadow="False">

            <VerticalStackLayout Spacing="5">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Search by Category"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151" />
                    <SearchBar x:Name="CategorySearchBar" Margin="0,0,0,5"
                               Placeholder="Type category name"
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="#F9FAFB" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Search by Item"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151" />
                    <SearchBar x:Name="ItemSearchBar" Margin="0,0,0,5"
                               Placeholder="Type item name"
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="#F9FAFB" />
                </VerticalStackLayout>
                
                
            </VerticalStackLayout>
            
        </Frame>

        <CollectionView Grid.Row="2"
                        x:Name="ShortageItemsCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0"
                           Padding="18"
                           CornerRadius="18"
                           BorderColor="#E5E7EB"
                           BackgroundColor="White"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding Name}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding CategoryName, StringFormat='Category: {0}'}"
                                   FontSize="14"
                                   TextColor="#1D4ED8"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding Unit, StringFormat='Unit: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding SupplierDisplay}"
                                   IsVisible="{Binding HasSupplierInfo}"
                                   FontSize="14"
                                   TextColor="#374151"
                                   LineBreakMode="WordWrap" />      

                            <Label Text="{Binding CurrentQuantity, StringFormat='Current: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding MinimumThreshold, StringFormat='Minimum Threshold: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding MissingText}"
                                   TextColor="#991B1B"
                                   FontAttributes="Bold"
                                   FontSize="15" />

                            <Label Text="Below Threshold"
                                   TextColor="#DC2626"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Stretch"
                                        AlignContent="Start">

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#B91C1C"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Record Movement"
                                        Clicked="OnRecordMovementClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="View History"
                                        Clicked="OnViewHistoryClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="White"
                                        BorderColor="#D1D5DB"
                                        BorderWidth="1.5"
                                        TextColor="#111827"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>