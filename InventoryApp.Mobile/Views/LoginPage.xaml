<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.LoginPage"
             Title="Login"
             BackgroundColor="#F7F9FC">

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,32"
                             Spacing="20"
                             VerticalOptions="Center">

            <VerticalStackLayout Spacing="6">
                <Label Text="Stockify"
                       FontSize="34"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1F2937" />

                <Label Text="Inventory management for growing organizations"
                       FontSize="15"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280" Padding="0,0,0,2"/>
            </VerticalStackLayout>

            <Frame Padding="22"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False"
                   MaximumWidthRequest="460"
                   HorizontalOptions="Fill">      
                <VerticalStackLayout Spacing="16">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sign in"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="Enter your email"
                               Keyboard="Email"
                               ClearButtonVisibility="WhileEditing"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Password"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Enter your password"
                               IsPassword="True"
                               BackgroundColor="#F9FAFB"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <Button Text="Login"
                            Clicked="OnLoginClicked"
                            CornerRadius="10"
                            HeightRequest="48"
                            BackgroundColor="#1D4ED8"
                            TextColor="White"
                            FontAttributes="Bold"
                            Margin="0,6,0,0" />

                    <Label x:Name="MessageLabel"
                           TextColor="#B91C1C"
                           FontSize="14" 
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="No account yet?"
                       FontSize="14"
                       TextColor="#6B7280" />
                <Label Text="Register"
                       TextColor="#1D4ED8"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterLabelTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>