<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.RecordStockMovementPage"
             Title="Record Stock Movement">

    <ScrollView>
        <VerticalStackLayout Padding="20,0,20,0" Spacing="14">

            <Label x:Name="ItemNameLabel"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label x:Name="CurrentQuantityLabel"
                   FontSize="16"
                   TextColor="#555555" />

            <Frame Padding="16"
                   CornerRadius="16"
                   BorderColor="#D9D9D9"
                   HasShadow="False">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Movement Type"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Picker x:Name="TransactionTypePicker"
                            Title="Select movement type">
                        <Picker.Items>
                            <x:String>Restock</x:String>
                            <x:String>Usage</x:String>
                            <x:String>Waste</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Quantity"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Entry x:Name="QuantityEntry"
                           Placeholder="Enter quantity"
                           Keyboard="Numeric" />

                    <Label Text="Note"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Editor x:Name="NoteEditor"
                            Placeholder="Optional note"
                            AutoSize="TextChanges"
                            HeightRequest="120" />

                </VerticalStackLayout>
            </Frame>

            <Button Text="Save Movement"
                    Clicked="OnSaveClicked"
                    CornerRadius="5"
                    HeightRequest="40"
                    MaximumWidthRequest="180"
                    BackgroundColor="DarkBlue"
                    TextColor="White"
                    HorizontalOptions="Center" />

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>