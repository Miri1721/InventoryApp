<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ItemsPage"
             Title="Items">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Items"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label x:Name="MessageLabel"
               TextColor="Red"
               FontSize="14" />

        <Button Text="Edit" Clicked="OnEditClicked" CommandParameter="{Binding .}" />
        
        <Button Text="Add Item" Clicked="OnAddItemClicked" />
        
        <CollectionView x:Name="ItemsCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,5" BorderColor="LightGray">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   FontSize="20"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Description}"
                                   FontSize="14" />
                            <Label Text="{Binding Unit, StringFormat='Unit: {0}'}"
                                   FontSize="14" />
                            <Label Text="{Binding CurrentQuantity, StringFormat='Current Quantity: {0}'}"
                                   FontSize="14" />
                            <Label Text="{Binding MinimumThreshold, StringFormat='Minimum Threshold: {0}'}"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>