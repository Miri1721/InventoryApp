<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.CategoryItemsPage"
             Title="Category Items"
             BackgroundColor="#F7F9FC">

    <Grid RowDefinitions="Auto,*" Padding="20,5,20,5" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <VerticalStackLayout>
                <Label x:Name="CategoryTitleLabel"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#111827" />
                <Label x:Name="CategoryDescriptionLabel"
                       FontSize="15"
                       TextColor="#6B7280"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
            <Label x:Name="MessageLabel"
                   TextColor="#B91C1C"
                   FontSize="14"
                   LineBreakMode="WordWrap" />

            <Frame Padding="16"
                   CornerRadius="18"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">

                <VerticalStackLayout Spacing="12">

                    <SearchBar x:Name="ItemSearchBar"
                               IsVisible="False"
                               Placeholder="Search items in this category"
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="#F9FAFB" />

                    <Grid x:Name="SortContainer"
                          IsVisible="False"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="12"
                          VerticalOptions="Center">
                        <Label Text="Sort by"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#374151"
                               VerticalOptions="Center" />

                        <Picker Grid.Column="1"
                                x:Name="SortPicker"
                                SelectedIndexChanged="OnSortChanged"
                                BackgroundColor="#F9FAFB">
                            <Picker.Items>
                                <x:String>Name A-Z</x:String>
                                <x:String>Name Z-A</x:String>
                                <x:String>Quantity Low-High</x:String>
                                <x:String>Quantity High-Low</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <Button Text="Add Item"
                            Clicked="OnAddItemClicked"
                            CornerRadius="10"
                            HeightRequest="48"
                            MaximumWidthRequest="180"
                            HorizontalOptions="Start"
                            BackgroundColor="White"
                            BorderColor="#D1D5DB"
                            BorderWidth="1.5"
                            TextColor="#111827"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="ItemsCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="18"
                           CornerRadius="18"
                           BorderColor="#E5E7EB"
                           BackgroundColor="White"
                           HasShadow="False">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding IsActiveAndBelowThreshold}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#FEF2F2" />
                            </DataTrigger>

                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding IsDeactivated}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#F3F4F6" />
                            </DataTrigger>
                        </Frame.Triggers>

                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Center" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="#DC2626"
                                        Padding="10,4"
                                        StrokeShape="RoundRectangle 12"
                                        IsVisible="{Binding ShowDeactivatedBadge}">
                                    <Label Text="Deactivated"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                </Border>
                            </Grid>

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding Unit, StringFormat='Unit: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding Supplier, StringFormat='Supplier: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding CurrentQuantity, StringFormat='Current Quantity: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding MinimumThreshold, StringFormat='Minimum Threshold: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding MissingText}"
                                   IsVisible="{Binding ShowBelowThresholdWarning}"
                                   TextColor="#991B1B"
                                   FontAttributes="Bold"
                                   FontSize="15" />

                            <Label Text="Below Threshold"
                                   IsVisible="{Binding ShowBelowThresholdWarning}"
                                   TextColor="#DC2626"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Stretch"
                                        AlignContent="Start">

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowEditButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowDeactivateButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Reactivate"
                                        Clicked="OnReactivateClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowReactivateButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowDeleteButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#B91C1C"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Record Movement"
                                        Clicked="OnRecordMovementClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowRecordMovementButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="View History"
                                        Clicked="OnViewHistoryClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowViewHistoryButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="White"
                                        BorderColor="#D1D5DB"
                                        BorderWidth="1.5"
                                        TextColor="#111827"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>