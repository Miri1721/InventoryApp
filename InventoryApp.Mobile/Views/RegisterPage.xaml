<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.RegisterPage"
             Title="Register"
             BackgroundColor="#F7F9FC">

    <ScrollView>
        <VerticalStackLayout Padding="24,32,24,32"
                             Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label Text="Create account"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1F2937" />

                <Label Text="Set up your organization and start managing inventory"
                       FontSize="15"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280" />
            </VerticalStackLayout>
            <Frame Padding="22"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False"
                   MaximumWidthRequest="560"
                   HorizontalOptions="Fill">        

                <VerticalStackLayout Spacing="18">

                    <Label Text="Personal Information"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="First Name"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                            <Entry x:Name="FirstNameEntry"
                                   Placeholder="Enter first name"
                                   BackgroundColor="#F9FAFB"
                                   HeightRequest="48" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Last Name"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                            <Entry x:Name="LastNameEntry"
                                   Placeholder="Enter last name"
                                   BackgroundColor="#F9FAFB"
                                   HeightRequest="48" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="ID Number"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="IdNumberEntry"
                               Placeholder="Enter ID number"
                               Keyboard="Numeric"
                               BackgroundColor="#F9FAFB"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="Enter email"
                               Keyboard="Email"
                               BackgroundColor="#F9FAFB"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             BackgroundColor="#E5E7EB" />

                    <Label Text="Organization Setup"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label Text="Choose whether you want to create a new organization or join an existing one."
                           FontSize="14"
                           TextColor="#6B7280" />

                    <Frame Padding="14"
                           CornerRadius="14"
                           BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Organization Choice"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />

                            <HorizontalStackLayout Spacing="20">
                                <RadioButton x:Name="NewOrganizationRadioButton"
                                             Content="New organization"
                                             GroupName="OrganizationMode"
                                             IsChecked="True"
                                             CheckedChanged="OnOrganizationModeChanged" />

                                <RadioButton x:Name="ExistingOrganizationRadioButton"
                                             Content="Existing organization"
                                             GroupName="OrganizationMode"
                                             CheckedChanged="OnOrganizationModeChanged" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <VerticalStackLayout x:Name="NewOrganizationSection"
                                         Spacing="12">
                        <Label Text="You will be registered as the manager of this organization."
                               FontSize="13"
                               TextColor="#6B7280"
                               LineBreakMode="WordWrap" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Organization Name"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                            <Entry x:Name="OrganizationNameEntry"
                                   Placeholder="Enter organization name"
                                   BackgroundColor="#F9FAFB"
                                   HeightRequest="48" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Organization Type"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                            <Picker x:Name="OrganizationTypePicker"
                                    Title="Select organization type"
                                    BackgroundColor="#F9FAFB">
                                <Picker.Items>
                                    <x:String>Cafe</x:String>
                                    <x:String>Restaurant</x:String>
                                    <x:String>Clothes Shop</x:String>
                                    <x:String>Kindergarten</x:String>
                                    <x:String>Grocery Store</x:String>
                                    <x:String>Bakery</x:String>
                                    <x:String>Pharmacy</x:String>
                                    <x:String>Office</x:String>
                                    <x:String>Flower Shop</x:String>
                                    <x:String>Other</x:String>
                                </Picker.Items>
                            </Picker>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="ExistingOrganizationSection"
                                         Spacing="12"
                                         IsVisible="False">
                        <Label Text="You will be registered as a worker in this organization, with limited permissions compared to the manager."
                               FontSize="13"
                               TextColor="#6B7280"
                               LineBreakMode="WordWrap" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Choose Existing Organization"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                            <Picker x:Name="ExistingOrganizationPicker"
                                    Title="Select organization"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    BackgroundColor="#F9FAFB" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             BackgroundColor="#E5E7EB" />

                    <Label Text="Security"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Password"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Enter password"
                               IsPassword="True"
                               BackgroundColor="#F9FAFB"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Confirm Password"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Entry x:Name="ConfirmPasswordEntry"
                               Placeholder="Confirm password"
                               IsPassword="True"
                               BackgroundColor="#F9FAFB"
                               HeightRequest="48" />
                    </VerticalStackLayout>

                    <Button Text="Register"
                            Clicked="OnRegisterClicked"
                            CornerRadius="10"
                            HeightRequest="48"
                            BackgroundColor="#1D4ED8"
                            TextColor="White"
                            FontAttributes="Bold"
                            Margin="0,8,0,0" />

                    <Label x:Name="MessageLabel"
                           TextColor="#B91C1C"
                           FontSize="14"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>