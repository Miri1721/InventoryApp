<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <VerticalStackLayout Spacing="8">
                <Label x:Name="WelcomeLabel"
                       FontSize="28"
                       FontAttributes="Bold" />

                <Label x:Name="OrganizationLabel"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="DarkBlue" />

                <Label x:Name="OrganizationTypeLabel"
                       FontSize="16"
                       TextColor="#555555" />

                <Label x:Name="EmailLabel"
                       FontSize="16" />

                <Label x:Name="RoleLabel"
                       FontSize="16" />

                <Label x:Name="OrganizationIdLabel"
                       FontSize="13"
                       TextColor="#777777"
                       LineBreakMode="CharacterWrap" />
            </VerticalStackLayout>

            <!-- Divider -->
            <BoxView HeightRequest="1"
                     BackgroundColor="#DDDDDD"
                     Margin="0,6,0,2" />

            <!-- Summary -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Summary"
                       FontSize="24"
                       FontAttributes="Bold" />

                <Label x:Name="CategoriesCountLabel"
                       FontSize="17" />

                <Label x:Name="ItemsCountLabel"
                       FontSize="17" />

                <Label x:Name="ShortageCountLabel"
                       FontSize="17"
                       TextColor="DarkRed"
                       FontAttributes="Bold" />
            </VerticalStackLayout>

            <!-- Divider -->
            <BoxView HeightRequest="1"
                     BackgroundColor="#DDDDDD"
                     Margin="0,6,0,2" />

            <!-- Actions -->
            <FlexLayout Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="Start"
                        AlignItems="Stretch"
                        AlignContent="Start">

                <Button Text="Categories"
                        Clicked="OnCategoriesClicked"
                        Margin="0,0,10,10"
                        CornerRadius="8"
                        HeightRequest="44"
                        MinimumWidthRequest="140"
                        BackgroundColor="DarkBlue"
                        TextColor="White"
                        FlexLayout.Basis="180"
                        FlexLayout.Grow="1" />

                <Button Text="Low Stock Items"
                        Clicked="OnShortageItemsClicked"
                        Margin="0,0,10,10"
                        CornerRadius="8"
                        HeightRequest="44"
                        MinimumWidthRequest="140"
                        BackgroundColor="DarkBlue"
                        TextColor="White"
                        FlexLayout.Basis="180"
                        FlexLayout.Grow="1" />
            </FlexLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>