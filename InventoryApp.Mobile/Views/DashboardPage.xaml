<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="#F7F9FC">

    <ScrollView>
        <VerticalStackLayout Padding="20,0,20,0" Spacing="5">
            <Frame Padding="15"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">

                <VerticalStackLayout Spacing="8">
                    <Label x:Name="WelcomeLabel"
                           FontSize="25"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label x:Name="OrganizationLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1D4ED8" />

                    <Label x:Name="OrganizationTypeLabel"
                           FontSize="15"
                           TextColor="#6B7280" />

                    <Label x:Name="EmailLabel"
                           FontSize="15"
                           TextColor="#374151" />

                    <Label x:Name="RoleLabel"
                           FontSize="15"
                           TextColor="#374151" />

                    <Label x:Name="OrganizationIdLabel"
                           FontSize="12"
                           TextColor="#9CA3AF"
                           LineBreakMode="CharacterWrap" />

                    <Button Text="Logout"
                            Clicked="OnLogoutClicked"
                            CornerRadius="10"
                            HeightRequest="44"
                            MaximumWidthRequest="160"
                            HorizontalOptions="Start"
                            BackgroundColor="White"
                            BorderColor="#D1D5DB"
                            BorderWidth="1.5"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            Margin="0,6,0,6" />
                </VerticalStackLayout>
            </Frame>

            <!-- Summary card -->
            <Frame Padding="15"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Summary"
                           FontSize="25"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="CategoriesCountLabel"
                               FontSize="17"
                               TextColor="#374151" />

                        <Label x:Name="ItemsCountLabel"
                               FontSize="17"
                               TextColor="#374151" />

                        <Label x:Name="ShortageCountLabel"
                               FontSize="17" Padding="0,0,0,5"
                               FontAttributes="Bold"
                               TextColor="#B91C1C" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Actions card -->
            <Frame Padding="15"
                   CornerRadius="20"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Actions"
                           FontSize="25"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                JustifyContent="Start"
                                AlignItems="Stretch"
                                AlignContent="Start">

                        <Button Text="Categories"
                                Clicked="OnCategoriesClicked"
                                Margin="0,0,12,12"
                                CornerRadius="10"
                                HeightRequest="48"
                                MinimumWidthRequest="150"
                                BackgroundColor="#1D4ED8"
                                TextColor="White"
                                FontAttributes="Bold"
                                FlexLayout.Basis="190"
                                FlexLayout.Grow="1" />

                        <Button Text="Items To Reorder"
                                Clicked="OnShortageItemsClicked"
                                Margin="0,0,12,12"
                                CornerRadius="10"
                                HeightRequest="48"
                                MinimumWidthRequest="150"
                                BackgroundColor="#1D4ED8"
                                TextColor="White"
                                FontAttributes="Bold"
                                FlexLayout.Basis="190"
                                FlexLayout.Grow="1" />

                        <Button x:Name="ExportExcelButton"
                                Text="Export Excel Report"
                                Clicked="OnExportExcelReportClicked"
                                Margin="0,0,12,12"
                                CornerRadius="10"
                                HeightRequest="48"
                                MinimumWidthRequest="170"
                                BackgroundColor="#1D4ED8"
                                TextColor="White"
                                FontAttributes="Bold"
                                FlexLayout.Basis="210"
                                FlexLayout.Grow="1" />

                        <Button x:Name="StaffButton"
                                Text="Staff"
                                Clicked="OnStaffClicked"
                                Margin="0,0,12,12"
                                CornerRadius="10"
                                HeightRequest="48"
                                MinimumWidthRequest="150"
                                BackgroundColor="#1D4ED8"
                                TextColor="White"
                                FontAttributes="Bold"
                                FlexLayout.Basis="190"
                                FlexLayout.Grow="1"
                                IsVisible="False" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>