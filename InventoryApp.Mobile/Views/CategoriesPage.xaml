<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.CategoriesPage"
             Title="Categories"
             BackgroundColor="#F7F9FC">

    <Grid RowDefinitions="Auto,*" Padding="20,5,20,5" RowSpacing="5">

        <VerticalStackLayout Grid.Row="0" Spacing="5" HorizontalOptions="Fill"
                             >
            <Label Text="Manage your inventory categories"
                   FontSize="15"
                   TextColor="#6B7280" />
            <Label x:Name="MessageLabel"
                   TextColor="#B91C1C"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
            
            <Frame Padding="16"
                   CornerRadius="18"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   HasShadow="False">

                <VerticalStackLayout Spacing="12">
                    <SearchBar x:Name="CategorySearchBar"
                               IsVisible="False"
                               Placeholder="Search categories"
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="#F9FAFB" />

                    <Grid ColumnDefinitions="Auto,*"
                          x:Name="SortPickerGrid"
                          ColumnSpacing="12"
                          IsVisible="False"
                          VerticalOptions="Center">
                        <Label Text="Sort by"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#374151"
                               VerticalOptions="Center" />

                        <Picker Grid.Column="1"
                                x:Name="SortPicker"
                                SelectedIndexChanged="OnSortChanged"
                                BackgroundColor="#F9FAFB">
                            <Picker.Items>
                                <x:String>Name A-Z</x:String>
                                <x:String>Name Z-A</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <Button Text="Add Category"
                            Clicked="OnAddCategoryClicked"
                            CornerRadius="10"
                            HeightRequest="48"
                            MaximumWidthRequest="180"
                            HorizontalOptions="Start"
                            BackgroundColor="White"
                            BorderColor="#D1D5DB"
                            BorderWidth="1.5"
                            TextColor="#111827"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="CategoriesCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="18"
                           CornerRadius="18"
                           BorderColor="#E5E7EB"
                           BackgroundColor="White"
                           HasShadow="False">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame"
                                         Binding="{Binding IsDeactivated}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#F3F4F6" />
                            </DataTrigger>
                        </Frame.Triggers>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Center" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="#DC2626"
                                        Padding="10,4"
                                        StrokeShape="RoundRectangle 12"
                                        IsVisible="{Binding ShowDeactivatedBadge}">
                                    <Label Text="Deactivated"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                </Border>
                            </Grid>

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />

                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Stretch"
                                        AlignContent="Start">

                                <Button Text="View Items"
                                        Clicked="OnViewItemsClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowEditButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowDeactivateButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Reactivate"
                                        Clicked="OnReactivateClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowReactivateButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48"
                                        MinimumWidthRequest="150"
                                        BackgroundColor="#1D4ED8"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding ShowDeleteButton}"
                                        Margin="0,0,5,5"
                                        CornerRadius="10"
                                        HeightRequest="48" MinimumWidthRequest="150"
                                        BackgroundColor="#B91C1C"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>