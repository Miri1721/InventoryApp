<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.CategoriesPage"
             Title="Categories">

    <Grid RowDefinitions="Auto, *" Padding="20,0,0,0">
        <VerticalStackLayout Grid.Row="0" Spacing="12" HorizontalOptions="Start"
                             Padding="5,0,0,0">
            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />

            <Button Text="Add Category"
                    Clicked="OnAddCategoryClicked"
                    CornerRadius="5"
                    HeightRequest="40"
                    MaximumWidthRequest="180"
                    HorizontalOptions="Center"
                    BackgroundColor="DarkBlue"
                    TextColor="White" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="CategoriesCollectionView"
                        Margin="0,16,0,0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12"
                           Padding="10"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#555555"
                                   LineBreakMode="WordWrap" />

                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Stretch"
                                        AlignContent="Start">

                                <Button Text="View Items"
                                        Clicked="OnViewItemsClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="130"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,5"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="110"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="120"
                                        FlexLayout.Grow="1" />

                                <Button Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        Margin="0,0,10,0"
                                        CornerRadius="5"
                                        HeightRequest="40"
                                        MinimumWidthRequest="130"
                                        BackgroundColor="DarkBlue"
                                        TextColor="White"
                                        FlexLayout.Basis="150"
                                        FlexLayout.Grow="1" />
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>