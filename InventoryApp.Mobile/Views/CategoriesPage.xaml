<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.CategoriesPage"
             Title="Categories">

    <Grid RowDefinitions="Auto, *" Padding="20">
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
            <Button Text="Add Category"
                    Clicked="OnAddCategoryClicked"
                    CornerRadius="5" HeightRequest="40"
                    MaximumWidthRequest="180" BackgroundColor="DarkBlue"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="CategoriesCollectionView"
                        Margin="0,16,0,0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,18"
                           Padding="16"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="7">
                            <Label Text="{Binding Name}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="#555555"
                                   LineBreakMode="WordWrap" />
                            <HorizontalStackLayout Spacing="10">
                                <Button Grid.Column="0"
                                        Text="Edit"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="5" HeightRequest="40"
                                        MaximumWidthRequest="180"
                                        BackgroundColor="DarkBlue"/>
                                <Button Grid.Column="1"
                                        Text="Deactivate"
                                        Clicked="OnDeactivateClicked"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="5" HeightRequest="40"
                                        MaximumWidthRequest="180"               
                                        BackgroundColor="DarkBlue"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>