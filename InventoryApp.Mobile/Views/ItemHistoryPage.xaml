<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ItemHistoryPage"
             Title="Item History">

    <Grid RowDefinitions="Auto,*" Padding="20,0,20,0">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label x:Name="ItemNameLabel"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="HistoryCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="14"
                           Margin="0"
                           CornerRadius="16"
                           BorderColor="#D9D9D9"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding TransactionType}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding QuantityChangeText, StringFormat='Change: {0}'}"
                                   FontSize="15"
                                   TextColor="DarkBlue" />

                            <Label Text="{Binding QuantityBefore, StringFormat='Before: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding QuantityAfter, StringFormat='After: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding Note, StringFormat='Note: {0}'}"
                                   FontSize="14"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding CreatedByEmail, StringFormat='By: {0}'}"
                                   FontSize="13"
                                   TextColor="#555555" />

                            <Label Text="{Binding CreatedAtLocalText, StringFormat='When: {0}'}"
                                   FontSize="13"
                                   TextColor="#555555" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>