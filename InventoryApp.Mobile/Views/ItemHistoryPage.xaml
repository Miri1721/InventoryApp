<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Mobile.Views.ItemHistoryPage"
             Title="Item History"
             BackgroundColor="#F7F9FC">

    <Grid RowDefinitions="Auto,*" Padding="20,5,20,0" RowSpacing="5">
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <VerticalStackLayout Spacing="6">
                <Label x:Name="ItemNameLabel"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#111827" />

                <Label Text="View the movement history of this item"
                       FontSize="15"
                       TextColor="#6B7280" />
            </VerticalStackLayout>

            <Label x:Name="MessageLabel"
                   TextColor="#B91C1C"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="HistoryCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="18"
                           Margin="0"
                           CornerRadius="18"
                           BorderColor="#E5E7EB"
                           BackgroundColor="White"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding TransactionType}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label Text="{Binding QuantityChangeText, StringFormat='Change: {0}'}"
                                   FontSize="15"
                                   TextColor="#1D4ED8"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding QuantityBefore, StringFormat='Before: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding QuantityAfter, StringFormat='After: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151" />

                            <Label Text="{Binding Note, StringFormat='Note: {0}'}"
                                   FontSize="14"
                                   TextColor="#374151"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding CreatedByEmail, StringFormat='By: {0}'}"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />

                            <Label Text="{Binding CreatedAtLocalText, StringFormat='When: {0}'}"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>